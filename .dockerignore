# ---------------------------------------------------------------
# Exclude files that contain Windows-absolute paths or are
# generated output — they must not be copied into the Docker
# build context or they will poison the Linux Flutter build.
# ---------------------------------------------------------------

# Flutter tool cache — contains package_config.json with absolute
# Windows paths (C:\Users\...) that break dart format inside Docker
frontend/.dart_tool/

# Compiled output — not needed, keeps context small
frontend/build/

# Generated plugin registry files — regenerated by flutter pub get
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages

# Generated l10n Dart files — regenerated by flutter build web
frontend/lib/l10n/app_localizations.dart
frontend/lib/l10n/app_localizations_en.dart
frontend/lib/l10n/app_localizations_nl.dart
frontend/lib/l10n/app_localizations_es.dart

# Android / iOS / Desktop build artefacts
frontend/android/.gradle/
frontend/android/app/.cxx/
frontend/ios/Pods/
frontend/linux/build/
frontend/macos/build/
frontend/windows/build/

# IDE state
frontend/.idea/
**/.DS_Store

# Backend — never needed in the web build context
backend/pb_data/
backend/web/