# ==========================================
# POCKETBASE ADMIN SETUP
# ==========================================
ADMIN_EMAIL="admin@example.com"

# DOCKER PASSWORD RULES:
# 1. ALWAYS wrap your password in double quotes ("") so special characters like # or ! don't break the setup.
# 2. If your password contains a dollar sign ($), you MUST type it twice ($$) so Docker doesn't think it's a variable.
# Example: If your password is My#Secure$Password!
# You must write it as: "My#Secure$$Password!"
ADMIN_PASSWORD="your_secure_password_here"