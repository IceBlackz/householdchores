# ==========================================
# POCKETBASE ADMIN SETUP
# ==========================================
ADMIN_EMAIL="admin@example.com"

# DOCKER PASSWORD RULES:
# 1. ALWAYS wrap your password in double quotes ("") so special characters like # or ! don't break setup.
# 2. If your password contains a dollar sign ($), type it twice ($$) so Docker doesn't treat it as a variable.
# Example: password My#Secure$Pass! → write as "My#Secure$$Pass!"
ADMIN_PASSWORD="your_secure_password_here"

# ==========================================
# HOME ASSISTANT INTEGRATION (optional)
# ==========================================
# Webhook URL to POST to when a chore is completed.
# Leave empty or remove this line to disable.
# HA_WEBHOOK_URL=http://your-ha:8123/api/webhook/your-webhook-id
